<LayoutComponents.page_content>
  <:header>
    <LayoutComponents.header current_user={@current_user}>
      <:title>Maintenance</:title>
    </LayoutComponents.header>
  </:header>
  <LayoutComponents.centered>
    <div class="flex flex-col gap-4">
      <div
        id="refresh-adaptors-card"
        class="bg-white shadow-xs rounded-lg border border-gray-200 p-6 flex items-start justify-between gap-6"
      >
        <div class="flex flex-col">
          <h2 class="text-lg font-semibold text-secondary-900">
            Refresh Adaptor Registry
          </h2>
          <p class="mt-1 text-sm text-secondary-600">
            Re-fetch the list of available adaptors and their versions.
          </p>
        </div>
        <.button
          theme="primary"
          phx-click="refresh_adaptors"
          id="refresh-adaptors-button"
        >
          Run
        </.button>
      </div>
    </div>
  </LayoutComponents.centered>
</LayoutComponents.page_content>
