    "@tsconfig/strictest": "^2.0.5",
    "@total-typescript/ts-reset": "^0.6.1",
    "@types/jsonpath": "^0.2.4",
    "@types/marked": "^4.0.8",
    "@types/phoenix": "^1.6.6",
    "@types/phoenix_live_view": "^0.20.0",
