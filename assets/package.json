    "d3-timer": "^3.0.1",
    "esbuild-plugin-copy": "^2.1.1",
    "esbuild-postcss": "^0.0.4",
    "immer": "^10.0.1",
    "jsonpath": "^1.1.1",
    "marked": "^4.2.4",
    "monaco-editor": "^0.43.0",
    "morphdom": "^2.7.4",
    "p-debounce": "^4.0.0",
