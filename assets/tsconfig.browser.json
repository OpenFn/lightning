{
  "extends": ["@tsconfig/strictest/tsconfig.json", "./tsconfig.base.json"],
  "compilerOptions": {
    "composite": true,
    "lib": ["es2020", "dom", "dom.iterable"],
    "module": "esnext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "rootDir": "../",
    "paths": {
      "#/*": ["./js/*"]
    }
  },
  "include": ["js/**/*", "vendor/**/*", "dev-server/**/*", "*.d.ts"],
  "exclude": ["node_modules/**"]
}
